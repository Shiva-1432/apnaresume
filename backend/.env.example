# Database
MONGODB_URI=your_mongodb_connection_string

# Authentication (must be 32+ characters)
JWT_SECRET=your_super_secret_key_minimum_32_characters_long

# AI
GEMINI_API_KEY=your_gemini_api_key

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@apnaresume.com

# Monitoring
SENTRY_DSN=your_sentry_dsn
SENTRY_TRACES_SAMPLE_RATE=0.1

# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://apnaresume.com

# Feature Limits
ANALYSIS_LIMIT_PER_HOUR=5
ANALYSIS_LIMIT_PER_DAY=20
JOB_MATCH_LIMIT_PER_HOUR=8
JOB_MATCH_LIMIT_PER_DAY=40
SKILL_GAP_LIMIT_PER_HOUR=6
SKILL_GAP_LIMIT_PER_DAY=30
